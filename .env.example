# ─────────────────────────────────────────────────────────────────────────────
# BlazeUp Automation — environment template
#
# Single merged `blazeup` domain (SA + partner share one API gateway). Copy this
# template to the one config file the framework loads, then edit:
#
#     cp .env.example config/blazeup/.env
#
# The SA/admin actor and the partner actor are distinguished by ADMIN_* / PARTNER_*
# keys — not separate files. NEVER commit real .env files (gitignored: config/*/.env).
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared API gateway ───────────────────────────────────────────────────────
# One API root for both actors. Must NOT equal a UI origin below — settings.py
# rejects that to catch pointing API calls at a UI server.
API_BASE_URL=https://api.stg.blazeup.ai

# ── Admin / SuperAdmin actor (SA endpoints /v1/sa/*) ─────────────────────────
# Drives most setup + all SA-facing tests. The generic settings aliases
# (settings.base_url / test_email / test_password) resolve to these.
ADMIN_BASE_URL=https://stgsa.blazeup.ai
ADMIN_EMAIL=your-sa-user@example.com
ADMIN_PASSWORD=your-password

# ── Partner actor (partner endpoints /v1/partner/*) ──────────────────────────
# Optional: the current partner-portal tests mint a throwaway partner from the SA
# side, so these are only needed for direct partner-login tests.
PARTNER_BASE_URL=https://stgpartners.blazeup.ai
PARTNER_EMAIL=your-partner-user@example.com
PARTNER_PASSWORD=your-password

# ── Browser ──────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER=chromium                 # chromium | firefox | webkit
SLOW_MO=0                        # ms delay between Playwright actions (debugging)
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900

# ── API timing ───────────────────────────────────────────────────────────────
DEFAULT_RESPONSE_TIME_MS=30000   # warn threshold (ms) for slow API responses

# ── AI failure-triage (utils/ai_triage.py) ───────────────────────────────────
# Post-run tool that reads a run's test.log and classifies WHY each test failed.
#   python -m utils.ai_triage results/run_YYYYMMDD_HHMMSS
# Provider-agnostic: only the selected provider's key is needed.
AI_PROVIDER=gemini               # gemini | groq | ollama
AI_MODEL=gemini-2.0-flash        # gemini-2.0-flash (free) | llama-3.1-8b-instant | qwen2.5 ...
GEMINI_API_KEY=                  # free key: https://aistudio.google.com/apikey
# GROQ_API_KEY=                  # free key: https://console.groq.com/keys
# OLLAMA_BASE_URL=http://localhost:11434   # local, no key (run `ollama serve`)
