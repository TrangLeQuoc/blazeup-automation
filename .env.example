# ─────────────────────────────────────────────────────────────────────────────
# BlazeUp Automation — environment template
#
# This is a TEMPLATE only.  The framework loads a PER-DOMAIN .env chosen by the
# BLAZEUP_DOMAIN env var (set automatically by each domain runner):
#
#     python -m runner.blazeup_admin.run_test    →  config/blazeup_admin/.env
#     python -m runner.blazeup_partner.run_test  →  config/blazeup_partner/.env
#
# First-time setup — copy this template into each domain folder, then edit:
#     cp .env.example config/blazeup_admin/.env
#     cp .env.example config/blazeup_partner/.env
#
# NEVER commit real .env files — they hold credentials and are gitignored
# (see .gitignore: config/*/.env).
# ─────────────────────────────────────────────────────────────────────────────

# ── Target URLs ──────────────────────────────────────────────────────────────
# UI app root and API root.  These must NOT be identical — settings.py rejects
# that to catch the copy-paste mistake of pointing API calls at the UI server.
BASE_URL=https://stgsa.blazeup.ai
API_BASE_URL=https://api.stg.blazeup.ai

# ── Credentials ──────────────────────────────────────────────────────────────
# Primary login user for this domain (used by the login_ui / login_api fixtures).
TEST_EMAIL=your-user@example.com
TEST_PASSWORD=your-password

# Optional second account (e.g. a partner-role login).  Leave blank if unused.
PARTNER_EMAIL=
PARTNER_PASSWORD=

# ── Browser ──────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER=chromium                 # chromium | firefox | webkit
SLOW_MO=0                        # ms delay between Playwright actions (debugging)
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900

# ── API timing ───────────────────────────────────────────────────────────────
DEFAULT_RESPONSE_TIME_MS=30000   # warn threshold (ms) for slow API responses
